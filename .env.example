OPENAI_API_KEY=sk-...
# または Gemini（Google AI Studio の無料枠）
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# AI_PROVIDER=gemini
# GEMINI_MODEL=gemini-2.5-flash
PORT=5173
BASE_URL=http://localhost:5173
SESSION_SECRET=change-this-session-secret
# 本番では NODE_ENV=production と https の BASE_URL を推奨（Cookie が Secure になります）
# NODE_ENV=production
# 永続ディスクへ保存するとき（未設定ならプロジェクト内 ./data）
# DATA_DIR=/var/lib/repotasu/data
# リバースプロキシの背後で X-Forwarded-* を信頼するとき
# TRUST_PROXY=1
# 強制的に Secure Cookie（https 終端があるのに BASE_URL が http のときなど）
# COOKIE_SECURE=true
# ローカル https 試験で Cookie を無理に非 Secure にしたいときだけ
# COOKIE_INSECURE=true
# 不審IPを遮断（カンマ区切り）
# BLOCKED_IPS=203.0.113.10,198.51.100.20
# 管理画面（/admin/security-status）アクセス許可IP（カンマ区切り）
# ADMIN_ALLOWED_IPS=203.0.113.10
# 管理画面Basic認証
# ADMIN_BASIC_USER=admin
# ADMIN_BASIC_PASS=change-this-admin-pass
# 管理画面ロックポリシー（10回以下）
# ADMIN_LOCK_MAX_ATTEMPTS=10
# ADMIN_LOCK_WINDOW_MS=900000
STRIPE_SECRET_KEY=sk_test_...
# 開発: `stripe listen` 実行時に表示される whsec_... をここに貼る（Dashboard の本番用とは別）
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard → 商品 → 価格ID（月額サブスクの price_...）
STRIPE_PRICE_ID=price_...

# Google OAuth（ログイン画面の「Googleでログイン」）
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# 承認済みリダイレクト URI: {BASE_URL}/api/auth/google/callback
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...

# 一般公開用（法的ページ・お問い合わせ）— 公開前に必ず埋める
LEGAL_OPERATOR_NAME=
LEGAL_ADDRESS=
SUPPORT_EMAIL=
LEGAL_PRO_PRICE=月額980円（税込）
LEGAL_UPDATED=2026年6月4日
# カンマ区切りで指定したメールアドレスを常時Pro扱いにする（開発/運営者向け）
# OWNER_PRO_EMAILS=you@example.com
